{
  "expo": {
    "name": "MindLog",
    "slug": "MindLog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Sesli not almak için mikrofon erişimi gereklidir.",
          "speechRecognitionPermission": "Konuşma tanıma için izin gereklidir.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.MindLog"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
